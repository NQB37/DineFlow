enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  DISABLED
}

model RestaurantTable {
  id        String      @id @default(uuid())

  code      String      @unique
  capacity  Int
  status    TableStatus @default(AVAILABLE)

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  bookings  Booking[]

  @@index([status])
}